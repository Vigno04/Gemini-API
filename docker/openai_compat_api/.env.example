# Required unless GEMINI_COOKIE_PATH already contains valid refreshed cookies.
GEMINI_SECURE_1PSID=

# Optional for some Google accounts.
GEMINI_SECURE_1PSIDTS=

# Optional proxy URL, e.g. http://user:pass@host:port
GEMINI_PROXY=

# Optional shared secret for the OpenAI-compatible API.
# If set, requests must include: Authorization: Bearer <value>
OPENAI_COMPAT_API_KEY=

# Optional image override for deployment on other servers.
# Example: ghcr.io/<your-org>/gemini-api-openai-compat:develop
OPENAI_COMPAT_IMAGE=

# Model used when request.model is missing.
OPENAI_COMPAT_DEFAULT_MODEL=gemini-3-flash

# Path used by gemini-webapi to persist refreshed cookies.
GEMINI_COOKIE_PATH=/data/cookies
