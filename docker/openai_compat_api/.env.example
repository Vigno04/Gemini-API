# Required unless GEMINI_COOKIE_PATH already contains valid refreshed cookies.
GEMINI_SECURE_1PSID=

# Optional for some Google accounts.
GEMINI_SECURE_1PSIDTS=

# Optional proxy URL, e.g. http://user:pass@host:port
GEMINI_PROXY=

# Optional shared secret for the OpenAI-compatible API.
# If set, requests must include: Authorization: Bearer <value>
OPENAI_COMPAT_API_KEY=

# Optional image override for deployment on other servers.
# Example: ghcr.io/<your-org>/gemini-api-openai-compat:develop
OPENAI_COMPAT_IMAGE=

# Model used when request.model is missing.
OPENAI_COMPAT_DEFAULT_MODEL=gemini-3-flash

# Force streaming responses for chat/completions even when request.stream=false.
OPENAI_COMPAT_FORCE_STREAM=false

# Max time for a single upstream generation before returning a graceful failure.
OPENAI_COMPAT_GENERATION_TIMEOUT_SECONDS=120

# Enable detailed request/response logging for debugging
OPENAI_COMPAT_DEBUG=false

# Language precedence:
# 1) OPENAI_COMPAT_LANGUAGE (if set) overrides everything.
# 2) If OPENAI_COMPAT_USE_ACCOUNT_LANGUAGE=true, use account language from Gemini metadata.
# 3) If OPENAI_COMPAT_USE_ACCOUNT_LANGUAGE=false and OPENAI_COMPAT_LANGUAGE is empty,
#    no fixed language is sent (model derives language from conversation).
# Baseline fallback is English when account language is enabled but unavailable.
OPENAI_COMPAT_USE_ACCOUNT_LANGUAGE=true

# Optional explicit language override, e.g. it, en, es, fr.
# When set, this takes precedence over OPENAI_COMPAT_USE_ACCOUNT_LANGUAGE.
OPENAI_COMPAT_LANGUAGE=

# Control generated images formatting (Embeds robust Base64 data strings natively inside markdown)
OPENAI_COMPAT_INLINE_IMAGES=true

# Outputs the hidden <thinking> monologue models use, mapped perfectly to API Usage metrics.
OPENAI_COMPAT_RETURN_REASONING=true

# Path used by gemini-webapi to persist refreshed cookies.
GEMINI_COOKIE_PATH=/data/cookies
